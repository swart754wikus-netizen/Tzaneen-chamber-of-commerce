# No database is used on this site — forms send straight to the admin via
# email and/or WhatsApp, and Articles content lives directly in the code
# (src/lib/articles.ts). Copy this file to .env.local and fill in whichever
# of the two notification channels below you want to use (at least one is
# required for forms to work — see PLAN.md for full setup steps).

# EmailJS — sends an email to admin@tzaneenchamber.org.za whenever someone
# submits the Call Back Request, Contact Us, or New Membership Application
# form. Sign up free at emailjs.com, connect the chamber's email as a
# service, and create one template. See PLAN.md for the exact template
# variable names each form sends.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# CallMeBot — sends an automatic WhatsApp message to the admin for all
# three forms. Free, no business account needed. Setup (the admin does
# this from her own phone, once): save +34 684 74 92 43 as a contact,
# send it the message "I allow callmebot to add me" on WhatsApp, and it
# replies with an API key. NEXT_PUBLIC_CALLMEBOT_PHONE is her WhatsApp
# number in international format with no + or spaces, e.g. 27821234567.
NEXT_PUBLIC_CALLMEBOT_PHONE=
NEXT_PUBLIC_CALLMEBOT_APIKEY=
