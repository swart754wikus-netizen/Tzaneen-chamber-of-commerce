# Copy to .env.local and fill in with your Firebase project's web app config
# (Firebase Console > Project Settings > General > Your apps > SDK setup and
# configuration). These are public client-side values — safe to expose in
# the browser bundle, access control lives in Firestore security rules.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# EmailJS — sends an email to the admin whenever someone submits the Call
# Back Request, Contact Us, or New Membership Application form. Sign up
# free at emailjs.com, connect admin@tzaneenchamber.org.za as an email
# service, and create a template. See PLAN.md for the exact template
# variable names each form sends. Without these, forms still save to
# Firestore — the admin just won't get an email about it.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
