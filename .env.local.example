# Copy to .env.local and fill in with your Firebase project's web app config
# (Firebase Console > Project Settings > General > Your apps > SDK setup and
# configuration). These are public client-side values — safe to expose in
# the browser bundle, access control lives in Firestore security rules.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# EmailJS — sends an email to the admin whenever someone submits the Call
# Back Request, Contact Us, or New Membership Application form. Sign up
# free at emailjs.com, connect admin@tzaneenchamber.org.za as an email
# service, and create a template. See PLAN.md for the exact template
# variable names each form sends. Without these, forms still save to
# Firestore — the admin just won't get an email about it.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# CallMeBot — sends an automatic WhatsApp message to the admin when someone
# submits the New Membership Application form only (not the other forms).
# Free, no business account needed. Setup (the admin does this from her own
# phone, once): save +34 684 74 92 43 as a contact, send it the message
# "I allow callmebot to add me" on WhatsApp, and it replies with an API key.
# NEXT_PUBLIC_CALLMEBOT_PHONE is her WhatsApp number in international
# format with no + or spaces, e.g. 27821234567. See PLAN.md for details.
# Without these, applications still save to Firestore and still email —
# WhatsApp is just an extra notification layer.
NEXT_PUBLIC_CALLMEBOT_PHONE=
NEXT_PUBLIC_CALLMEBOT_APIKEY=
